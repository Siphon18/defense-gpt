# ─── LLM Provider ───
# Set LLM_PROVIDER to "groq" or "gemini"
LLM_PROVIDER=groq

# ─── Groq ───
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Gemini ───
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── MongoDB Atlas ───
# Get your connection string from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/defensegpt?retryWrites=true&w=majority

# ─── Firecrawl Web Search (optional but recommended) ───
# Get your API key at: https://www.firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
